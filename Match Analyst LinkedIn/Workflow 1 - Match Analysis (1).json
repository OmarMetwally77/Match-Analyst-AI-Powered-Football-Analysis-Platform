    {
      "parameters": {
        "jsCode": "const resolved = $('Resolve Team IDs').first().json;\nconst fixtures = $('Fetch Fixtures By Date').first().json.response || [];\nconst ALLOWED = ['FT', 'AET', 'PEN'];\nconst match = fixtures.find(f => {\n  const home = f.teams.home.id;\n  const away = f.teams.away.id;\n  const validTeams = (home === resolved.team1Id && away === resolved.team2Id) || (home === resolved.team2Id && away === resolved.team1Id);\n  return validTeams && ALLOWED.includes(f.fixture.status.short);\n});\nreturn [{\n  json: {\n    ...resolved,\n    fixtureFound: !!match,\n    fixtureId: match ? match.fixture.id : null,\n    fixture: match || null\n  }\n}];"
      },
