    {
      "parameters": {
        "jsCode": "const validated = $('Validate Input').first().json;\nconst team1Results = $('Search Team 1').first().json.response || [];\nconst team2Results = $('Search Team 2').first().json.response || [];\nfunction exactMatch(results, name) {\n  const lower = name.toLowerCase();\n  let match = results.find(r => r.team && r.team.name && r.team.name.toLowerCase() === lower);\n  if (!match && results.length > 0) match = results[0];\n  return match ? match.team : null;\n}\nconst team1 = exactMatch(team1Results, validated.team1);\nconst team2 = exactMatch(team2Results, validated.team2);\nconst errors = [];\nif (!team1) errors.push('Could not resolve team1: ' + validated.team1);\nif (!team2) errors.push('Could not resolve team2: ' + validated.team2);\nreturn [{\n  json: {\n    team1Id: team1 ? team1.id : null,\n    team1Name: team1 ? team1.name : validated.team1,\n    team2Id: team2 ? team2.id : null,\n    team2Name: team2 ? team2.name : validated.team2,\n    matchDate: validated.matchDate,\n    teamsResolved: errors.length === 0,\n    errors\n  }\n}];"
      },
