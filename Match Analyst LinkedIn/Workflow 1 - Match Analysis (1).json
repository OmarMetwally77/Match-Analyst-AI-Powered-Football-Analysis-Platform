    {
      "parameters": {
        "jsCode": "const ctx = $('Calculate H2H Record').first().json;\nconst fixture = ctx.fixture || {};\nconst stats = $('Fetch Statistics').first().json.response || [];\nconst lineups = $('Fetch Lineups').first().json.response || [];\nconst injuries = $('Fetch Injuries').first().json.response || [];\nconst tactical = $('AI Tactical Analysis Agent').first().json.output || {};\nconst timelineOut = $('AI Match Timeline Agent').first().json.output || {};\nreturn [{\n  json: {\n    success: true,\n    fixture: fixture.fixture || null,\n    score: fixture.goals || null,\n    competition: fixture.league || null,\n    venue: (fixture.fixture && fixture.fixture.venue) || null,\n    stats,\n    events: ctx.rawTimeline,\n    lineups,\n    form: ctx.form,\n    injuries,\n    playerRatings: ctx.playerRatings,\n    motm: ctx.motm,\n    timeline: timelineOut.timeline || [],\n    analysis: tactical,\n    headToHead: ctx.h2h\n  }\n}];"
