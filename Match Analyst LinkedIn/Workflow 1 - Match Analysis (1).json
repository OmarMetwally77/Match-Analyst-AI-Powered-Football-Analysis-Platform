    {
      "parameters": {
        "jsCode": "const fixtureCtx = $('Find Fixture').first().json;\nfunction calcForm(fixtures, teamId) {\n  const results = [];\n  let points = 0;\n  for (const f of fixtures) {\n    const homeId = f.teams.home.id;\n    const isHome = homeId === teamId;\n    const homeGoals = f.goals.home;\n    const awayGoals = f.goals.away;\n    let result;\n    if (homeGoals === awayGoals) { result = 'D'; points += 1; }\n    else if ((isHome && homeGoals > awayGoals) || (!isHome && awayGoals > homeGoals)) { result = 'W'; points += 3; }\n    else { result = 'L'; }\n    results.push(result);\n  }\n  return { results, points };\n}\nconst team1Fixtures = $('Fetch Team 1 Form').first().json.response || [];\nconst team2Fixtures = $('Fetch Team 2 Form').first().json.response || [];\nreturn [{\n  json: {\n    ...fixtureCtx,\n    form: {\n      team1: calcForm(team1Fixtures, fixtureCtx.team1Id),\n      team2: calcForm(team2Fixtures, fixtureCtx.team2Id)\n    }\n  }\n}];"
      },
      "id": "40c44a42-fcc7-490e-83f7-6d2c0699ba6f",
      "name": "Calculate Team Form",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4032,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Calculate Team Form').first().json;\nconst playersResponse = $('Fetch Players').first().json.response || [];\nconst allPlayers = [];\nfor (const teamBlock of playersResponse) {\n  const teamId = teamBlock.team ? teamBlock.team.id : null;\n  for (const p of (teamBlock.players || [])) {\n    const stats = (p.statistics && p.statistics[0]) || {};\n    const rating = parseFloat(stats.games && stats.games.rating) || 0;\n    const goals = (stats.goals && stats.goals.total) || 0;\n    const assists = (stats.goals && stats.goals.assists) || 0;\n    const keyPasses = (stats.passes && stats.passes.key) || 0;\n    const position = stats.games && stats.games.position;\n    allPlayers.push({\n      teamId,\n      playerId: p.player.id,\n      name: p.player.name,\n      position,\n      rating,\n      goals,\n      assists,\n      keyPasses\n    });\n  }\n}\nfunction rankBy(list) {\n  return list.slice().sort((a, b) => {\n    if (b.rating !== a.rating) return b.rating - a.rating;\n    if (b.goals !== a.goals) return b.goals - a.goals;\n    if (b.assists !== a.assists) return b.assists - a.assists;\n    return b.keyPasses - a.keyPasses;\n  });\n}\nfunction bestByPosition(pos) {\n  const list = allPlayers.filter(p => (p.position || '').toUpperCase() === pos);\n  const ranked = rankBy(list);\n  return ranked.length ? ranked[0] : null;\n}\nconst playerRatings = {\n  bestGoalkeeper: bestByPosition('G'),\n  bestDefender: bestByPosition('D'),\n  bestMidfielder: bestByPosition('M'),\n  bestAttacker: bestByPosition('F')\n};\nconst motmRanked = rankBy(allPlayers);\nconst motm = motmRanked.length ? motmRanked[0] : null;\nreturn [{\n  json: {\n    ...ctx,\n    playerRatings,\n    motm\n  }\n}];"
      },
      "id": "338fde53-7b66-42c5-b432-7f4b16d795b1",
      "name": "Calculate Ratings and MOTM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4256,
        112
      ]
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Calculate Ratings and MOTM').first().json;\nconst events = $('Fetch Events').first().json.response || [];\nconst rawTimeline = events.map(e => ({\n  minute: (e.time.elapsed != null ? e.time.elapsed : '') + (e.time.extra ? ('+' + e.time.extra) : '') + \"'\",\n  type: (e.type || '').toLowerCase(),\n  detail: e.detail || '',\n  team: e.team ? e.team.name : null,\n  player: e.player ? e.player.name : null,\n  assist: e.assist ? e.assist.name : null\n}));\nreturn [{\n  json: {\n    ...ctx,\n    rawTimeline\n  }\n}];"
      },
      "id": "169bff35-b5f1-42f5-8aa8-519be72af1a0",
      "name": "Build Raw Timeline",
