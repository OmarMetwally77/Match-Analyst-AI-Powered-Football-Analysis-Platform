    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst errors = [];\nconst team1 = (item.team1 || '').trim();\nconst team2 = (item.team2 || '').trim();\nif (!team1) errors.push('team1 is required');\nif (!team2) errors.push('team2 is required');\nif (team1 && team2 && team1.toLowerCase() === team2.toLowerCase()) errors.push('team1 and team2 must be different');\nreturn [{\n  json: {\n    team1,\n    team2,\n    isValid: errors.length === 0,\n    errors\n  }\n}];"
