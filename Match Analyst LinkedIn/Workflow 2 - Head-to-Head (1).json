      "onError": "continueRegularOutput"
    },
    {
      "parameters": {
        "jsCode": "const ctx = $('Resolve Team IDs').first().json;\nconst ALLOWED = ['FT', 'AET', 'PEN'];\nconst allMeetings = $('Fetch H2H Meetings').first().json.response || [];\nconst completed = allMeetings.filter(f => ALLOWED.includes(f.fixture.status.short));\ncompleted.sort((a, b) => new Date(b.fixture.date) - new Date(a.fixture.date));\nconst totalMeetingsFound = completed.length;\nconst limited = totalMeetingsFound >= 10 ? completed.slice(0, 10) : completed;\nlet wins1 = 0, wins2 = 0, draws = 0;\nfor (const f of limited) {\n  const homeId = f.teams.home.id;\n  const homeGoals = f.goals.home;\n  const awayGoals = f.goals.away;\n  const team1IsHome = homeId === ctx.team1Id;\n  if (homeGoals === awayGoals) { draws++; }\n  else if ((team1IsHome && homeGoals > awayGoals) || (!team1IsHome && awayGoals > homeGoals)) { wins1++; }\n  else { wins2++; }\n}\nconst meetings = limited.map(f => ({\n  date: f.fixture.date ? f.fixture.date.substring(0, 10) : null,\n  competition: f.league ? f.league.name : null,\n  homeTeam: f.teams.home.name,\n  awayTeam: f.teams.away.name,\n  homeGoals: f.goals.home,\n  awayGoals: f.goals.away\n}));\nreturn [{\n  json: {\n    success: true,\n    team1: ctx.team1Name,\n    team2: ctx.team2Name,\n    totalMeetingsFound,\n    wins1,\n    wins2,\n    draws,\n    meetings\n  }\n}];"
      },
