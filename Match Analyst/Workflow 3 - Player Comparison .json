    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst errors = [];\nconst player1 = (item.player1 || '').trim();\nconst player2 = (item.player2 || '').trim();\nconst fixtureId = (item.fixtureId || '').toString().trim();\nif (!player1) errors.push('player1 is required');\nif (!player2) errors.push('player2 is required');\nif (!fixtureId) errors.push('fixture_id is required — please analyze a match first before comparing players');\nif (player1 && player2 && player1.toLowerCase() === player2.toLowerCase()) errors.push('player1 and player2 must be different');\nreturn [{\n  json: {\n    player1,\n    player2,\n    fixtureId,\n    hasFixtureId: !!fixtureId,\n    isValid: errors.length === 0,\n    errors\n  }\n}];"
      },
