        "jsCode": "const ctx = $('Build Match-Based Metrics').first().json;\nconst ai = $('AI Comparison Agent (Match)').first().json.output || {};\nreturn [{\n  json: {\n    success: true,\n    mode: 'match',\n    fixtureId: ctx.fixtureId,\n    player1: ctx.player1Metrics,\n    player2: ctx.player2Metrics,\n    comparison: ai.comparison || null\n  }\n}];"
