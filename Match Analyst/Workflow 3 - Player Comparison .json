    {
      "parameters": {
        "jsCode": "const ctx = $('Validate Input').first().json;\nconst teamBlocks = $('Fetch Fixture Players').first().json.response || [];\nconst allPlayers = [];\nfor (const block of teamBlocks) {\n  for (const p of (block.players || [])) {\n    allPlayers.push(p);\n  }\n}\nfunction findPlayer(name) {\n  const lower = name.toLowerCase();\n  return allPlayers.find(p => p.player && p.player.name && p.player.name.toLowerCase().includes(lower)) || null;\n}\nfunction extractMetrics(p) {\n  if (!p) return null;\n  const stats = (p.statistics && p.statistics[0]) || {};\n  return {\n    name: p.player.name,\n    playerId: p.player.id,\n    minutesPlayed: (stats.games && stats.games.minutes) || 0,\n    rating: parseFloat(stats.games && stats.games.rating) || null,\n    goals: (stats.goals && stats.goals.total) || 0,\n    assists: (stats.goals && stats.goals.assists) || 0,\n    shotsTotal: (stats.shots && stats.shots.total) || 0,\n    shotsOnTarget: (stats.shots && stats.shots.on) || 0,\n    passesTotal: (stats.passes && stats.passes.total) || 0,\n    keyPasses: (stats.passes && stats.passes.key) || 0,\n    passAccuracy: (stats.passes && stats.passes.accuracy) || null,\n    tackles: (stats.tackles && stats.tackles.total) || 0,\n    duelsWon: (stats.duels && stats.duels.won) || 0\n  };\n}\nconst p1Match = findPlayer(ctx.player1);\nconst p2Match = findPlayer(ctx.player2);\nconst errors = [];\nif (!p1Match) errors.push('\"' + ctx.player1 + '\" is not in either squad for this match. Please enter a player who played in this fixture.');\nif (!p2Match) errors.push('\"' + ctx.player2 + '\" is not in either squad for this match. Please enter a player who played in this fixture.');\nreturn [{\n  json: {\n    mode: 'match',\n    fixtureId: ctx.fixtureId,\n    playersFound: errors.length === 0,\n    errors,\n    player1Metrics: extractMetrics(p1Match),\n    player2Metrics: extractMetrics(p2Match)\n  }\n}];"
      },
