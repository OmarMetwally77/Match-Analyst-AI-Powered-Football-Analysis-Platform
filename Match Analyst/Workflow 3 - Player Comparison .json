    {
      "parameters": {
        "jsCode": "const ctx = $('Validate Input').first().json;\nconst player1Results = $('Search Player 1').first().json.response || [];\nconst player2Results = $('Search Player 2').first().json.response || [];\nfunction exactMatch(results, name) {\n  const lower = name.toLowerCase();\n  let match = results.find(r => r.player && r.player.name && r.player.name.toLowerCase().includes(lower));\n  if (!match && results.length > 0) match = results[0];\n  return match ? match.player : null;\n}\nconst player1 = exactMatch(player1Results, ctx.player1);\nconst player2 = exactMatch(player2Results, ctx.player2);\nconst errors = [];\nif (!player1) errors.push('Could not find player1: ' + ctx.player1);\nif (!player2) errors.push('Could not find player2: ' + ctx.player2);\nconst now = new Date();\nconst month = now.getUTCMonth() + 1;\nconst year = now.getUTCFullYear();\nconst currentSeason = month >= 7 ? year : year - 1;\nreturn [{\n  json: {\n    mode: 'season',\n    player1Id: player1 ? player1.id : null,\n    player1Name: player1 ? player1.name : ctx.player1,\n    player2Id: player2 ? player2.id : null,\n    player2Name: player2 ? player2.name : ctx.player2,\n    currentSeason,\n    playersResolved: errors.length === 0,\n    errors\n  }\n}];"
      },
