    {
      "parameters": {
        "jsCode": "const ctx = $('Determine Current Season').first().json;\nconst p1Response = ($('Fetch Player 1 Season Stats').first().json.response || [])[0] || null;\nconst p2Response = ($('Fetch Player 2 Season Stats').first().json.response || [])[0] || null;\nfunction aggregateMetrics(playerResponse, fallbackName) {\n  if (!playerResponse) return null;\n  const statsList = playerResponse.statistics || [];\n  let goals = 0, assists = 0, appearances = 0, minutes = 0, yellow = 0, red = 0, shotsTotal = 0, shotsOnTarget = 0, passesTotal = 0, keyPasses = 0, tacklesTotal = 0, ratingSum = 0, ratingCount = 0;\n  for (const s of statsList) {\n    goals += (s.goals && s.goals.total) || 0;\n    assists += (s.goals && s.goals.assists) || 0;\n    appearances += (s.games && s.games.appearences) || 0;\n    minutes += (s.games && s.games.minutes) || 0;\n    yellow += (s.cards && s.cards.yellow) || 0;\n    red += (s.cards && s.cards.red) || 0;\n    shotsTotal += (s.shots && s.shots.total) || 0;\n    shotsOnTarget += (s.shots && s.shots.on) || 0;\n    passesTotal += (s.passes && s.passes.total) || 0;\n    keyPasses += (s.passes && s.passes.key) || 0;\n    tacklesTotal += (s.tackles && s.tackles.total) || 0;\n    const r = parseFloat(s.games && s.games.rating);\n    if (!isNaN(r)) { ratingSum += r; ratingCount++; }\n  }\n  return {\n    name: (playerResponse.player && playerResponse.player.name) || fallbackName,\n    playerId: playerResponse.player ? playerResponse.player.id : null,\n    appearances,\n    minutesPlayed: minutes,\n    goals,\n    assists,\n    yellowCards: yellow,\n    redCards: red,\n    shotsTotal,\n    shotsOnTarget,\n    passesTotal,\n    keyPasses,\n    tacklesTotal,\n    averageRating: ratingCount > 0 ? Math.round((ratingSum / ratingCount) * 100) / 100 : null\n  };\n}\nconst p1 = aggregateMetrics(p1Response, ctx.player1Name);\nconst p2 = aggregateMetrics(p2Response, ctx.player2Name);\nreturn [{\n  json: {\n    mode: 'season',\n    season: ctx.currentSeason,\n    playersFound: !!(p1 && p2),\n    errors: [],\n    player1Metrics: p1,\n    player2Metrics: p2\n  }\n}];"
      },
